# Copy to ".env" in the project root and fill in values from:
# Supabase → Project Settings → API (Project URL + anon public key)
#
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the app bundle.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Set to "true" to bypass login during local development (never use in production)
EXPO_PUBLIC_DEV_SKIP_AUTH=false
EXPO_PUBLIC_DEV_EMAIL=your-test-account@email.com
EXPO_PUBLIC_DEV_PASSWORD=your-test-password
